alias open='xdg-open'
alias rm='rm -rIv'
alias cp='cp -rv'
alias mv='mv -v'
alias mkdir='mkdir -v'
alias rmdir='rmdir -v'
alias ..='cd ..'
alias cat='bat'
alias grep='rg'
alias la='exa --icons -a --group-directories-first'
alias ll='exa --icons -lah --group-directories-first'
alias ls='exa --icons --group-directories-first'
alias tree='exa --icons --tree'
alias dotpush='$HOME/.local/scripts/push.sh'
alias bsrc="nano $HOME/.config/bspwm/bspwmrc"
alias sxrc="nano $HOME/.config/sxhkd/sxhkdrc"
alias picomrc="nano $HOME/.config/picom/picom.conf"
alias updates="checkupdates && paru -Qum"
alias ix="curl -F 'f:1=<-' ix.io"
